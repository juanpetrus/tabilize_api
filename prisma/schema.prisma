generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum DocumentType {
  DAS
  CONTRACT
  INVOICE
  TAX_REPORT
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum RecurrenceInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

// ─── Auth interna (contador / equipe) ────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedTeams    Team[]       @relation("TeamOwner")
  teamMembers   TeamMember[]
  createdTasks  Task[]       @relation("TaskCreator")
  assignedTasks Task[]       @relation("TaskAssignee")
}

// ─── Escritório / Workspace ───────────────────────────────────────────────────

model Team {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User         @relation("TeamOwner", fields: [ownerId], references: [id])
  members   TeamMember[]
  companies Company[]
  tasks     Task[]
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

// ─── Empresa cliente ─────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  teamId    String
  name      String
  cnpj      String?  @unique
  email     String?
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team            Team             @relation(fields: [teamId], references: [id])
  companyUsers    CompanyUser[]
  documents       Document[]
  tasks           Task[]
  serviceRequests ServiceRequest[]
  payments        Payment[]
}

// ─── Portal cliente (login da empresa) ───────────────────────────────────────

model CompanyUser {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String   @unique
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id])
  serviceRequests ServiceRequest[]
}

// ─── Documentos ──────────────────────────────────────────────────────────────

model Document {
  id          String       @id @default(uuid())
  companyId   String
  name        String
  type        DocumentType
  fileUrl     String?
  description String?
  dueDate     DateTime?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ─── Tarefas ─────────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(uuid())
  teamId      String
  companyId   String?
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  assigneeId  String?
  creatorId   String
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  team     Team    @relation(fields: [teamId], references: [id])
  company  Company? @relation(fields: [companyId], references: [id])
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator  User    @relation("TaskCreator", fields: [creatorId], references: [id])
}

// ─── Pedidos / Solicitações do cliente ───────────────────────────────────────

model ServiceRequest {
  id            String               @id @default(uuid())
  companyId     String
  companyUserId String
  title         String
  description   String?
  status        ServiceRequestStatus @default(OPEN)
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  company     Company     @relation(fields: [companyId], references: [id])
  companyUser CompanyUser @relation(fields: [companyUserId], references: [id])
}

// ─── Cobranças ────────────────────────────────────────────────────────────────

model Payment {
  id                  String              @id @default(uuid())
  companyId           String
  description         String
  amount              Decimal             @db.Decimal(10, 2)
  dueDate             DateTime
  status              PaymentStatus       @default(PENDING)
  paidAt              DateTime?
  referenceMonth      String?
  isRecurring         Boolean             @default(false)
  recurrenceInterval  RecurrenceInterval?
  recurrenceEndDate   DateTime?
  recurrenceGroupId   String?
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum DocumentType {
  DAS
  CONTRACT
  INVOICE
  TAX_REPORT
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum RecurrenceInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum CndType {
  FEDERAL        // CND Federal (Receita/PGFN)
  ESTADUAL       // CND Estadual (SEFAZ)
  MUNICIPAL      // CND Municipal (Prefeitura)
  FGTS           // CRF FGTS (Caixa)
  TRABALHISTA    // CNDT (TST)
}

enum CndStatus {
  VALID          // Certidão válida (negativa)
  EXPIRED        // Certidão vencida
  PENDING        // Aguardando consulta
  POSITIVE       // Certidão positiva (com débitos)
  POSITIVE_NEGATIVE // Certidão positiva com efeito de negativa
  ERROR          // Erro na consulta
}

enum BillingCycle {
  MONTH
  YEAR
}

enum EmployeeStatus {
  ACTIVE           // Ativo
  DISMISSED        // Demitido
  ON_LEAVE         // Afastado (licença, férias, etc)
  VACATION         // Férias
}

enum ContractType {
  CLT              // Consolidação das Leis do Trabalho
  PJ               // Pessoa Jurídica
  INTERN           // Estagiário
  TEMP             // Temporário
  APPRENTICE       // Aprendiz
}

enum DismissalType {
  WITHOUT_CAUSE    // Sem justa causa
  WITH_CAUSE       // Com justa causa
  RESIGNATION      // Pedido de demissão
  MUTUAL_AGREEMENT // Acordo mútuo (reforma trabalhista)
  CONTRACT_END     // Término de contrato
}

enum PayslipItemType {
  EARNING   // Vencimento/Provento
  DEDUCTION // Desconto
}

// ─── Auth interna (contador / equipe) ────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  password             String
  isActive             Boolean   @default(true)
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  ownedTeams    Team[]       @relation("TeamOwner")
  teamMembers   TeamMember[]
  createdTasks  Task[]       @relation("TaskCreator")
  assignedTasks Task[]       @relation("TaskAssignee")
}

// ─── Planos ───────────────────────────────────────────────────────────────────

model Plan {
  id                 String   @id
  name               String
  description        String
  priceMonthly       Int?
  priceYearly        Int?
  features           String[]
  idProductMonthly   String?
  idProductYearly    String?
  url                String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  teams Team[]
}

// ─── Escritório / Workspace ───────────────────────────────────────────────────

model Team {
  id                 String    @id @default(uuid())
  name               String
  ownerId            String
  isActive           Boolean   @default(true)
  planId             String?
  billingCycle       BillingCycle @default(MONTH)
  subscriptionStatus String    @default("INACTIVE")
  subscriptionId     String?
  customerId         String?
  subscriptionExpiry DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  owner     User         @relation("TeamOwner", fields: [ownerId], references: [id])
  plan      Plan?        @relation(fields: [planId], references: [id])
  members   TeamMember[]
  companies Company[]
  boards     Board[]
  tasks      Task[]
  driveItems DriveItem[]
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

// ─── Empresa cliente ─────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  teamId    String
  name      String
  cnpj      String?  @unique
  email     String?
  phone     String?
  address   String?
  isActive      Boolean   @default(true)
  sefazUltNsu   String?
  sefazLastSync DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  team               Team                 @relation(fields: [teamId], references: [id])
  companyUsers       CompanyUser[]
  activeForUsers     CompanyUser[]        @relation("ActiveCompany")
  companyUserLinks   CompanyUserCompany[] // Usuários do portal com acesso
  driveShares        DriveItemShare[]
  tasks              Task[]
  serviceRequests    ServiceRequest[]
  payments           Payment[]
  certificate        CompanyCertificate?
  sefazNFes          SefazNFe[]
  sefazEventos       SefazEvento[]
  cnds               Cnd[]                // Certidões negativas
  employees          Employee[]           // Funcionários
}

// ─── Portal cliente (login da empresa) ───────────────────────────────────────

model CompanyUser {
  id                 String   @id @default(uuid())
  companyId          String   // Empresa padrão (backward compatibility)
  activeCompanyId    String?  // Empresa ativa atual (pode ser diferente da padrão)
  name               String
  email              String   @unique
  password           String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company         Company               @relation(fields: [companyId], references: [id])
  activeCompany   Company?              @relation("ActiveCompany", fields: [activeCompanyId], references: [id])
  companies       CompanyUserCompany[]  // Empresas que o usuário pode acessar
  serviceRequests ServiceRequest[]
}

// ─── Relação many-to-many: Usuário do portal ↔ Empresas ─────────────────────

model CompanyUserCompany {
  id            String   @id @default(uuid())
  companyUserId String
  companyId     String
  isDefault     Boolean  @default(false)  // Empresa padrão do usuário
  createdAt     DateTime @default(now())

  companyUser CompanyUser @relation(fields: [companyUserId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyUserId, companyId])
}

// ─── Drive Unificado ──────────────────────────────────────────────────────────

model DriveItem {
  id          String  @id @default(uuid())
  teamId      String
  name        String
  path        String  // "/DAS/2024/Janeiro" ou "/DAS/2024/Janeiro/arquivo.pdf"
  isDirectory Boolean @default(false)

  // Metadados do arquivo (quando isDirectory = false)
  fileUrl  String?
  mimeType String?
  size     Int?

  // Campos extras
  description     String?
  competenceMonth Int? // 1-12 (para DAS, boletos, etc)
  competenceYear  Int? // 2024, 2025...

  // Controle
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team   Team             @relation(fields: [teamId], references: [id])
  shares DriveItemShare[]

  @@unique([teamId, path])
  @@index([teamId, path])
}

// Compartilhamento com empresas específicas
model DriveItemShare {
  id          String   @id @default(uuid())
  driveItemId String
  companyId   String
  canUpload   Boolean  @default(false) // Cliente pode fazer upload nessa pasta
  createdAt   DateTime @default(now())

  driveItem DriveItem @relation(fields: [driveItemId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id])

  @@unique([driveItemId, companyId])
}

// ─── Certificado digital da empresa ──────────────────────────────────────────

model CompanyCertificate {
  id        String    @id @default(uuid())
  companyId String    @unique
  certUrl   String
  password  String
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ─── Documentos fiscais SEFAZ ────────────────────────────────────────────────

model SefazNFe {
  id             String    @id @default(uuid())
  companyId      String
  chave          String
  nsu            String?
  tipo           String?   // EMITIDA | RECEBIDA
  status         String    @default("AUTORIZADA") // AUTORIZADA | CANCELADA
  emitenteCnpj   String?
  emitenteNome   String?
  destinCnpj     String?
  destinNome     String?
  valor          Decimal?  @db.Decimal(15, 2)
  serie          String?
  numero         String?
  dataEmissao    DateTime?
  xmlGzip        String?   @db.Text
  temXmlCompleto Boolean   @default(false)
  modelo         String?   // 55 = NF-e | 65 = NFC-e
  manifestacao   String?   // CIENCIA | CONFIRMADA | DESCONHECIMENTO | NAO_REALIZADA
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company  Company       @relation(fields: [companyId], references: [id])
  eventos  SefazEvento[]

  @@unique([companyId, chave])
}

model SefazEvento {
  id         String    @id @default(uuid())
  companyId  String
  nfeId      String?
  chaveNFe   String
  nsu        String
  tpEvento   String?
  xEvento    String?
  dataEvento DateTime?
  protocolo  String?
  schema     String
  xmlGzip    String    @db.Text
  createdAt  DateTime  @default(now())

  company Company    @relation(fields: [companyId], references: [id])
  nfe     SefazNFe?  @relation(fields: [nfeId], references: [id])

  @@unique([companyId, nsu])
}

// ─── Quadros / Setores ───────────────────────────────────────────────────────

model Board {
  id        String   @id @default(uuid())
  teamId    String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team  Team   @relation(fields: [teamId], references: [id])
  tasks Task[]
}

// ─── Tarefas ─────────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(uuid())
  teamId      String
  boardId     String
  companyId   String?
  parentId    String?
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  assigneeId  String?
  creatorId   String
  order       Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  team           Team                @relation(fields: [teamId], references: [id])
  board          Board               @relation(fields: [boardId], references: [id])
  company        Company?            @relation(fields: [companyId], references: [id])
  assignee       User?               @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator        User                @relation("TaskCreator", fields: [creatorId], references: [id])
  parent         Task?               @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks       Task[]              @relation("TaskSubtasks")
  checklistItems TaskChecklistItem[]
}

// ─── Checklist de Tarefas ────────────────────────────────────────────────────

model TaskChecklistItem {
  id        String   @id @default(uuid())
  taskId    String
  text      String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ─── Pedidos / Solicitações do cliente ───────────────────────────────────────

model ServiceRequest {
  id            String               @id @default(uuid())
  companyId     String
  companyUserId String
  title         String
  description   String?
  status        ServiceRequestStatus @default(OPEN)
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  company     Company     @relation(fields: [companyId], references: [id])
  companyUser CompanyUser @relation(fields: [companyUserId], references: [id])
}

// ─── Cobranças ────────────────────────────────────────────────────────────────

model Payment {
  id                  String              @id @default(uuid())
  companyId           String
  description         String
  amount              Decimal             @db.Decimal(10, 2)
  dueDate             DateTime
  status              PaymentStatus       @default(PENDING)
  paidAt              DateTime?
  referenceMonth      String?
  isRecurring         Boolean             @default(false)
  recurrenceInterval  RecurrenceInterval?
  recurrenceEndDate   DateTime?
  recurrenceGroupId   String?
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ─── Certidões Negativas de Débitos ──────────────────────────────────────────

model Cnd {
  id             String    @id @default(uuid())
  companyId      String
  type           CndType
  status         CndStatus @default(PENDING)

  // Dados da certidão
  issueDate      DateTime?          // Data de emissão
  expirationDate DateTime?          // Data de validade
  protocolNumber String?            // Número do protocolo/certidão

  // Arquivo para download
  fileUrl        String?            // URL do PDF no S3
  fileName       String?            // Nome original do arquivo

  // Controle de sincronização
  autoSync       Boolean   @default(true)  // Sincronizar automaticamente
  lastSyncAt     DateTime?                 // Última tentativa de sync
  lastError      String?                   // Último erro de sync

  // Metadados
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, type])  // Uma certidão de cada tipo por empresa
  @@index([companyId])
  @@index([expirationDate])    // Para alertas de vencimento
}

// ─── Funcionários (Folha de Pagamento) ──────────────────────────────────────

model Employee {
  id            String         @id @default(uuid())
  companyId     String

  // Dados pessoais
  name          String
  cpf           String
  rg            String?
  birthDate     DateTime?
  email         String?
  phone         String?
  address       String?

  // Dados trabalhistas
  admissionDate DateTime
  dismissalDate DateTime?
  dismissalType DismissalType?
  position      String                 // Cargo
  department    String?                // Departamento/Setor
  salary        Decimal       @db.Decimal(10, 2)
  workCard      String?                // Número CTPS
  pis           String?                // PIS/PASEP

  // Status e tipo de contrato
  status        EmployeeStatus @default(ACTIVE)
  contractType  ContractType   @default(CLT)

  // Metadados
  notes         String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  payslips      Payslip[]
  documents     EmployeeDocument[]

  @@unique([companyId, cpf])
  @@index([companyId])
  @@index([status])
}

// ─── Documentos do Funcionário ──────────────────────────────────────────────

model EmployeeDocument {
  id          String   @id @default(uuid())
  employeeId  String
  name        String           // Nome do documento (ex: "RG", "CPF", "Contrato")
  fileUrl     String
  fileName    String
  mimeType    String?
  uploadedAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

// ─── Holerites / Contracheques ──────────────────────────────────────────────

model Payslip {
  id              String   @id @default(uuid())
  employeeId      String
  competenceMonth Int              // Mês de referência (1-12)
  competenceYear  Int              // Ano de referência

  // Valores
  grossSalary     Decimal  @db.Decimal(10, 2)  // Salário bruto
  netSalary       Decimal  @db.Decimal(10, 2)  // Salário líquido
  deductions      Decimal? @db.Decimal(10, 2)  // Total de descontos

  // Bases de cálculo
  baseInss        Decimal? @db.Decimal(10, 2)  // Base de cálculo INSS
  baseIrrf        Decimal? @db.Decimal(10, 2)  // Base de cálculo IRRF
  fgtsValue       Decimal? @db.Decimal(10, 2)  // Valor FGTS do mês

  // Arquivo PDF
  fileUrl         String
  fileName        String

  // Metadados
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  items    PayslipItem[]

  @@unique([employeeId, competenceMonth, competenceYear])
  @@index([employeeId])
  @@index([competenceYear, competenceMonth])
}

model PayslipItem {
  id          String          @id @default(uuid())
  payslipId   String
  code        String          // Código da rubrica (ex: "001", "101")
  description String          // Descrição (ex: "Salário Base", "INSS")
  type        PayslipItemType // EARNING ou DEDUCTION
  reference   String?         // Referência (ex: "30 dias", "11%")
  value       Decimal         @db.Decimal(10, 2)

  payslip Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  @@index([payslipId])
}


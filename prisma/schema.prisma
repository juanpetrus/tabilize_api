generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum DocumentType {
  DAS
  CONTRACT
  INVOICE
  TAX_REPORT
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum RecurrenceInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum CndType {
  FEDERAL        // CND Federal (Receita/PGFN)
  ESTADUAL       // CND Estadual (SEFAZ)
  MUNICIPAL      // CND Municipal (Prefeitura)
  FGTS           // CRF FGTS (Caixa)
  TRABALHISTA    // CNDT (TST)
}

enum CndStatus {
  VALID          // Certidão válida (negativa)
  EXPIRED        // Certidão vencida
  PENDING        // Aguardando consulta
  POSITIVE       // Certidão positiva (com débitos)
  POSITIVE_NEGATIVE // Certidão positiva com efeito de negativa
  ERROR          // Erro na consulta
}

enum LicenseType {
  ALVARA_FUNCIONAMENTO   // Alvará / Licença de Funcionamento (Prefeitura)
  BOMBEIROS_AVCB         // AVCB / CLCB (Corpo de Bombeiros)
  SANITARIA              // Licença / Alvará Sanitário (Vigilância Sanitária)
  AMBIENTAL              // Licença Ambiental (LP/LI/LO)
  INSCRICAO_MUNICIPAL    // CCM / Inscrição Municipal (ISS)
  INSCRICAO_ESTADUAL     // Inscrição Estadual (ICMS / SEFAZ)
  JUNTA_COMERCIAL        // Registro na Junta Comercial / NIRE
  CONSELHO_CLASSE        // Registro em conselho de classe (CRC, CREA, CRM, OAB...)
  OUTRO                  // Outro tipo — usar o campo `name`
}

enum LicenseStatus {
  PENDING     // Em processo / aguardando emissão
  ACTIVE      // Vigente
  EXPIRED     // Vencida
  SUSPENDED   // Suspensa / em exigência
  CANCELLED   // Cancelada / baixada
}

enum BillingCycle {
  MONTH
  YEAR
}

enum EmployeeStatus {
  ACTIVE           // Ativo
  DISMISSED        // Demitido
  ON_LEAVE         // Afastado (licença, férias, etc)
  VACATION         // Férias
}

enum ContractType {
  CLT              // Consolidação das Leis do Trabalho
  PJ               // Pessoa Jurídica
  INTERN           // Estagiário
  TEMP             // Temporário
  APPRENTICE       // Aprendiz
}

enum DismissalType {
  WITHOUT_CAUSE    // Sem justa causa
  WITH_CAUSE       // Com justa causa
  RESIGNATION      // Pedido de demissão
  MUTUAL_AGREEMENT // Acordo mútuo (reforma trabalhista)
  CONTRACT_END     // Término de contrato
}

enum PayslipItemType {
  EARNING   // Vencimento/Provento
  DEDUCTION // Desconto
}

// ─── Fiscal: configuração de emissão por empresa ─────────────────────────────

enum Crt {
  SIMPLES_NACIONAL                   // CRT 1
  SIMPLES_NACIONAL_EXCESSO_SUBLIMITE // CRT 2
  REGIME_NORMAL                      // CRT 3 (Lucro Real ou Presumido)
  MEI                                // CRT 4
}

enum RegimeEspecial {
  SEM_REGIME
  MICROEMPRESA               // ME
  EMPRESA_PEQUENO_PORTE      // EPP
  MICROEMPRESA_MUNICIPAL     // ME municipal (ISS)
  SOCIEDADE_PROFISSIONAIS    // Sociedade uniprofissional (ISS fixo)
  COOPERATIVA                // Regime tributário de cooperativa
  ESTIMATIVA                 // Regime de estimativa (ICMS/ISS)
  PRODUTOR_RURAL
  SUBSTITUTO_TRIBUTARIO
  OUTRO
}

enum Estabelecimento {
  MATRIZ
  FILIAL
}

enum IndicadorAtividade {
  INDUSTRIAL
  EQUIPARADO_INDUSTRIAL
  COMERCIANTE
  PRESTADOR_SERVICO
  ATIVIDADE_FINANCEIRA
  TRANSPORTE
  COMUNICACAO
  OUTROS
}

enum UsarCstCsosn {
  CST
  CSOSN
  NAO
}

enum AmbienteSefaz {
  PRODUCAO       // tpAmb=1
  HOMOLOGACAO    // tpAmb=2
}

enum TipoContingencia {
  NORMAL
  SVC_AN         // SEFAZ Virtual de Contingência - Ambiente Nacional
  SVC_RS         // SEFAZ Virtual de Contingência - RS
  EPEC           // Evento Prévio de Emissão em Contingência
  FS_IA          // Formulário de Segurança - Impressor Auxiliar
  OFFLINE        // Contingência offline (NFC-e)
}

enum TipoPessoa {
  PF             // Pessoa Física (CPF, 11 dígitos)
  PJ             // Pessoa Jurídica (CNPJ, 14 dígitos)
}

enum IndicadorIeDestinatario {
  CONTRIBUINTE_ICMS    // 1 - Contribuinte ICMS (informa IE)
  ISENTO               // 2 - Contribuinte isento de inscrição no cadastro de contribuintes
  NAO_CONTRIBUINTE     // 9 - Não Contribuinte (pode ou não possuir IE)
}

// Origem da mercadoria (campo `orig` na tag CST/CSOSN ICMS) — valores fixos 0-8
enum MercadoriaOrigem {
  NACIONAL                                  // 0 - Nacional (exceto 3, 4, 5 e 8)
  ESTRANGEIRA_IMPORTACAO_DIRETA             // 1 - Estrangeira, importação direta (exceto 6)
  ESTRANGEIRA_MERCADO_INTERNO               // 2 - Estrangeira, adquirida no mercado interno (exceto 7)
  NACIONAL_CI_SUPERIOR_40                   // 3 - Nacional, conteúdo importação > 40% e ≤ 70%
  NACIONAL_PPB                              // 4 - Nacional, produção em conformidade com PPB
  NACIONAL_CI_INFERIOR_40                   // 5 - Nacional, conteúdo importação ≤ 40%
  ESTRANGEIRA_IMP_DIRETA_SEM_SIMILAR        // 6 - Estrangeira, importação direta, sem similar nacional (CAMEX)
  ESTRANGEIRA_MERCADO_INTERNO_SEM_SIMILAR   // 7 - Estrangeira, mercado interno, sem similar nacional (CAMEX)
  NACIONAL_CI_SUPERIOR_70                   // 8 - Nacional, conteúdo importação > 70%
}

// ─── NF-e emitida — enums ──────────────────────────────────────────────────

enum NfeStatus {
  RASCUNHO        // Editável; ainda não enviada
  PROCESSANDO     // Enviada à SEFAZ, aguardando resposta
  AUTORIZADA      // Autorizada (cStat 100)
  REJEITADA       // Rejeitada pela SEFAZ
  DENEGADA        // Denegada (cStat 110)
  CANCELADA       // Autorizada e depois cancelada por evento
  INUTILIZADA     // Numeração inutilizada (não chegou a ser autorizada)
}

enum NfeFinalidade {
  NORMAL          // finNFe = 1
  COMPLEMENTAR    // finNFe = 2
  AJUSTE          // finNFe = 3
  DEVOLUCAO       // finNFe = 4
}

enum NfeTipoOperacao {
  ENTRADA         // tpNF = 0
  SAIDA           // tpNF = 1
}

enum NfeModFrete {
  POR_CONTA_EMITENTE              // 0 (CIF)
  POR_CONTA_DESTINATARIO          // 1 (FOB)
  POR_CONTA_TERCEIROS             // 2
  TRANSPORTE_PROPRIO_EMITENTE     // 3
  TRANSPORTE_PROPRIO_DESTINATARIO // 4
  SEM_TRANSPORTE                  // 9
}

// ─── Auth interna (contador / equipe) ────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  password             String
  isActive             Boolean   @default(true)
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  ownedTeams    Team[]       @relation("TeamOwner")
  teamMembers   TeamMember[]
  createdTasks  Task[]       @relation("TaskCreator")
  assignedTasks Task[]       @relation("TaskAssignee")
}

// ─── Planos ───────────────────────────────────────────────────────────────────

model Plan {
  id                 String   @id
  name               String
  description        String
  priceMonthly       Int?
  priceYearly        Int?
  features           String[]
  idProductMonthly   String?
  idProductYearly    String?
  url                String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  teams Team[]
}

// ─── Escritório / Workspace ───────────────────────────────────────────────────

model Team {
  id                 String    @id @default(uuid())
  name               String
  ownerId            String
  isActive           Boolean   @default(true)
  planId             String?
  billingCycle       BillingCycle @default(MONTH)
  subscriptionStatus String    @default("INACTIVE")
  subscriptionId     String?
  customerId         String?
  subscriptionExpiry DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  owner     User         @relation("TeamOwner", fields: [ownerId], references: [id])
  plan      Plan?        @relation(fields: [planId], references: [id])
  members   TeamMember[]
  companies Company[]
  boards     Board[]
  tasks      Task[]
  driveItems DriveItem[]
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

// ─── Empresa cliente ─────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  teamId    String
  name      String
  cnpj      String?  @unique
  email     String?
  phone     String?
  address   String?
  isActive      Boolean   @default(true)
  sefazUltNsu   String?
  sefazLastSync DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  team               Team                 @relation(fields: [teamId], references: [id])
  companyUsers       CompanyUser[]
  activeForUsers     CompanyUser[]        @relation("ActiveCompany")
  companyUserLinks   CompanyUserCompany[] // Usuários do portal com acesso
  driveShares        DriveItemShare[]
  tasks              Task[]
  serviceRequests    ServiceRequest[]
  payments           Payment[]
  certificate        CompanyCertificate?
  sefazNFes          SefazNFe[]
  sefazEventos       SefazEvento[]
  cnds               Cnd[]                // Certidões negativas
  licenses           License[]            // Licenças / legalização (alvarás etc.)
  employees          Employee[]           // Funcionários
  fiscalProfile      CompanyFiscalProfile?  // Dados fiscais (IE, IM, CRT, etc.)
  fiscalAddress      CompanyAddress?        // Endereço fiscal estruturado
  nfeConfig          CompanyNfeConfig?      // Configuração de emissão NF-e (modelo 55)
  customers          Customer[]             // Clientes/destinatários
  products           Product[]              // Produtos/serviços
  nfes               Nfe[]                  // NF-e emitidas pela empresa
  nfeInutilizacoes   NfeInutilizacao[]      // Inutilizações de numeração NF-e
}

// ─── Portal cliente (login da empresa) ───────────────────────────────────────

model CompanyUser {
  id                 String   @id @default(uuid())
  companyId          String   // Empresa padrão (backward compatibility)
  activeCompanyId    String?  // Empresa ativa atual (pode ser diferente da padrão)
  name               String
  email              String   @unique
  password           String
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company         Company               @relation(fields: [companyId], references: [id])
  activeCompany   Company?              @relation("ActiveCompany", fields: [activeCompanyId], references: [id])
  companies       CompanyUserCompany[]  // Empresas que o usuário pode acessar
  serviceRequests ServiceRequest[]
}

// ─── Relação many-to-many: Usuário do portal ↔ Empresas ─────────────────────

model CompanyUserCompany {
  id            String   @id @default(uuid())
  companyUserId String
  companyId     String
  isDefault     Boolean  @default(false)  // Empresa padrão do usuário
  createdAt     DateTime @default(now())

  companyUser CompanyUser @relation(fields: [companyUserId], references: [id], onDelete: Cascade)
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyUserId, companyId])
}

// ─── Drive Unificado ──────────────────────────────────────────────────────────

model DriveItem {
  id          String  @id @default(uuid())
  teamId      String
  name        String
  path        String  // "/DAS/2024/Janeiro" ou "/DAS/2024/Janeiro/arquivo.pdf"
  isDirectory Boolean @default(false)

  // Metadados do arquivo (quando isDirectory = false)
  fileUrl  String?
  mimeType String?
  size     Int?

  // Campos extras
  description     String?
  competenceMonth Int? // 1-12 (para DAS, boletos, etc)
  competenceYear  Int? // 2024, 2025...

  // Controle
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team   Team             @relation(fields: [teamId], references: [id])
  shares DriveItemShare[]

  @@unique([teamId, path])
  @@index([teamId, path])
}

// Compartilhamento com empresas específicas
model DriveItemShare {
  id          String   @id @default(uuid())
  driveItemId String
  companyId   String
  canUpload   Boolean  @default(false) // Cliente pode fazer upload nessa pasta
  createdAt   DateTime @default(now())

  driveItem DriveItem @relation(fields: [driveItemId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id])

  @@unique([driveItemId, companyId])
}

// ─── Certificado digital da empresa ──────────────────────────────────────────

model CompanyCertificate {
  id        String    @id @default(uuid())
  companyId String    @unique
  certUrl   String
  password  String
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ─── Documentos fiscais SEFAZ ────────────────────────────────────────────────

model SefazNFe {
  id             String    @id @default(uuid())
  companyId      String
  chave          String
  nsu            String?
  tipo           String?   // EMITIDA | RECEBIDA
  status         String    @default("AUTORIZADA") // AUTORIZADA | CANCELADA | DENEGADA
  emitenteCnpj   String?
  emitenteIe     String?   // IE do emitente (vem no resNFe e procNFe)
  emitenteNome   String?
  destinCnpj     String?
  destinNome     String?
  valor          Decimal?  @db.Decimal(15, 2)
  serie          String?
  numero         String?
  dataEmissao    DateTime?
  dataAutorizacao DateTime? // dhRecbto - data de autorização na SEFAZ
  xmlGzip        String?   @db.Text
  temXmlCompleto Boolean   @default(false)
  modelo         String?   // 55 = NF-e | 65 = NFC-e
  manifestacao   String?   // CIENCIA | CONFIRMADA | DESCONHECIMENTO | NAO_REALIZADA

  // Última tentativa de consulta consChNFe — útil para diagnóstico
  // (ex: cStat=632 indica prazo expirado p/ download do XML)
  lastSyncAt       DateTime?
  lastSyncCStat    String?
  lastSyncXMotivo  String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company  Company       @relation(fields: [companyId], references: [id])
  eventos  SefazEvento[]

  @@unique([companyId, chave])
}

model SefazEvento {
  id         String    @id @default(uuid())
  companyId  String
  nfeId      String?
  chaveNFe   String
  nsu        String
  tpEvento   String?
  xEvento    String?
  dataEvento DateTime?
  protocolo  String?
  schema     String
  xmlGzip    String    @db.Text
  createdAt  DateTime  @default(now())

  company Company    @relation(fields: [companyId], references: [id])
  nfe     SefazNFe?  @relation(fields: [nfeId], references: [id])

  @@unique([companyId, nsu])
}

// ─── Quadros / Setores ───────────────────────────────────────────────────────

model Board {
  id        String   @id @default(uuid())
  teamId    String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team  Team   @relation(fields: [teamId], references: [id])
  tasks Task[]
}

// ─── Tarefas ─────────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(uuid())
  teamId      String
  boardId     String
  companyId   String?
  parentId    String?
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  assigneeId  String?
  creatorId   String
  order       Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  team           Team                @relation(fields: [teamId], references: [id])
  board          Board               @relation(fields: [boardId], references: [id])
  company        Company?            @relation(fields: [companyId], references: [id])
  assignee       User?               @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator        User                @relation("TaskCreator", fields: [creatorId], references: [id])
  parent         Task?               @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks       Task[]              @relation("TaskSubtasks")
  checklistItems TaskChecklistItem[]
}

// ─── Checklist de Tarefas ────────────────────────────────────────────────────

model TaskChecklistItem {
  id        String   @id @default(uuid())
  taskId    String
  text      String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ─── Pedidos / Solicitações do cliente ───────────────────────────────────────

model ServiceRequest {
  id            String               @id @default(uuid())
  companyId     String
  companyUserId String
  title         String
  description   String?
  status        ServiceRequestStatus @default(OPEN)
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  company     Company     @relation(fields: [companyId], references: [id])
  companyUser CompanyUser @relation(fields: [companyUserId], references: [id])
}

// ─── Cobranças ────────────────────────────────────────────────────────────────

model Payment {
  id                  String              @id @default(uuid())
  companyId           String
  description         String
  amount              Decimal             @db.Decimal(10, 2)
  dueDate             DateTime
  status              PaymentStatus       @default(PENDING)
  paidAt              DateTime?
  referenceMonth      String?
  isRecurring         Boolean             @default(false)
  recurrenceInterval  RecurrenceInterval?
  recurrenceEndDate   DateTime?
  recurrenceGroupId   String?
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ─── Certidões Negativas de Débitos ──────────────────────────────────────────

model Cnd {
  id             String    @id @default(uuid())
  companyId      String
  type           CndType
  status         CndStatus @default(PENDING)

  // Dados da certidão
  issueDate      DateTime?          // Data de emissão
  expirationDate DateTime?          // Data de validade
  protocolNumber String?            // Número do protocolo/certidão

  // Arquivo para download
  fileUrl        String?            // URL do PDF no S3
  fileName       String?            // Nome original do arquivo

  // Controle de sincronização
  autoSync       Boolean   @default(true)  // Sincronizar automaticamente
  lastSyncAt     DateTime?                 // Última tentativa de sync
  lastError      String?                   // Último erro de sync

  // Metadados
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, type])  // Uma certidão de cada tipo por empresa
  @@index([companyId])
  @@index([expirationDate])    // Para alertas de vencimento
}

// ─── Legalização: Licenças / Alvarás ─────────────────────────────────────────

model License {
  id             String        @id @default(uuid())
  companyId      String
  type           LicenseType
  name           String                              // texto livre; obrigatório quando type = OUTRO
  status         LicenseStatus @default(PENDING)

  issuingBody    String?                             // órgão emissor ("Prefeitura de São Paulo", "Corpo de Bombeiros - SP")
  number         String?                             // nº do alvará / NIRE / inscrição
  protocolNumber String?                             // protocolo do processo
  issueDate      DateTime?                           // data de emissão
  expirationDate DateTime?                           // validade (null = sem validade definida — ex.: NIRE, inscrições)
  notes          String?

  // Arquivo (no R2, via StorageService)
  fileUrl        String?
  fileName       String?
  mimeType       String?

  // Cadeia de renovação
  renewedFromId  String?       @unique               // a License anterior que esta renova
  renewedFrom    License?      @relation("LicenseRenewal", fields: [renewedFromId], references: [id])
  renewal        License?      @relation("LicenseRenewal")  // a renovação desta (se já foi renovada)

  // Metadados
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([expirationDate])    // Para alertas de vencimento
  @@index([companyId, type])
}

// ─── Funcionários (Folha de Pagamento) ──────────────────────────────────────

model Employee {
  id            String         @id @default(uuid())
  companyId     String

  // Dados pessoais
  name          String
  cpf           String
  rg            String?
  birthDate     DateTime?
  email         String?
  phone         String?
  address       String?

  // Dados trabalhistas
  admissionDate DateTime
  dismissalDate DateTime?
  dismissalType DismissalType?
  position      String                 // Cargo
  department    String?                // Departamento/Setor
  salary        Decimal       @db.Decimal(10, 2)
  workCard      String?                // Número CTPS
  pis           String?                // PIS/PASEP

  // Status e tipo de contrato
  status        EmployeeStatus @default(ACTIVE)
  contractType  ContractType   @default(CLT)

  // Metadados
  notes         String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  payslips      Payslip[]
  documents     EmployeeDocument[]

  @@unique([companyId, cpf])
  @@index([companyId])
  @@index([status])
}

// ─── Documentos do Funcionário ──────────────────────────────────────────────

model EmployeeDocument {
  id          String   @id @default(uuid())
  employeeId  String
  name        String           // Nome do documento (ex: "RG", "CPF", "Contrato")
  fileUrl     String
  fileName    String
  mimeType    String?
  uploadedAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

// ─── Holerites / Contracheques ──────────────────────────────────────────────

model Payslip {
  id              String   @id @default(uuid())
  employeeId      String
  competenceMonth Int              // Mês de referência (1-12)
  competenceYear  Int              // Ano de referência

  // Valores
  grossSalary     Decimal  @db.Decimal(10, 2)  // Salário bruto
  netSalary       Decimal  @db.Decimal(10, 2)  // Salário líquido
  deductions      Decimal? @db.Decimal(10, 2)  // Total de descontos

  // Bases de cálculo
  baseInss        Decimal? @db.Decimal(10, 2)  // Base de cálculo INSS
  baseIrrf        Decimal? @db.Decimal(10, 2)  // Base de cálculo IRRF
  fgtsValue       Decimal? @db.Decimal(10, 2)  // Valor FGTS do mês

  // Arquivo PDF
  fileUrl         String
  fileName        String

  // Metadados
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  items    PayslipItem[]

  @@unique([employeeId, competenceMonth, competenceYear])
  @@index([employeeId])
  @@index([competenceYear, competenceMonth])
}

model PayslipItem {
  id          String          @id @default(uuid())
  payslipId   String
  code        String          // Código da rubrica (ex: "001", "101")
  description String          // Descrição (ex: "Salário Base", "INSS")
  type        PayslipItemType // EARNING ou DEDUCTION
  reference   String?         // Referência (ex: "30 dias", "11%")
  value       Decimal         @db.Decimal(10, 2)

  payslip Payslip @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  @@index([payslipId])
}

// ─── Catálogo CNAE (Classificação Nacional de Atividades Econômicas) ────────

model CnaeCode {
  codigo       String   @id              // "4711-3/01" (com máscara, formato visual padrão)
  descricao    String                    // "Comércio varejista de mercadorias..."

  // hierarquia denormalizada (origem: API IBGE)
  secao        String   @db.Char(1)      // "G"
  secaoDesc    String                    // "Comércio; reparação de veículos..."
  divisao      String                    // "47"
  grupo        String                    // "471"
  classe       String                    // "4711-3"

  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  fiscalProfiles CompanyFiscalProfile[]

  @@index([descricao])
  @@index([secao])
}

// ─── Configuração fiscal da empresa (1:1 com Company) ──────────────────────

model CompanyFiscalProfile {
  id                   String              @id @default(uuid())
  companyId            String              @unique
  companyCode          String?             // Código interno do contador (ex: "534569")
  inscricaoEstadual    String?             // IE — aceita texto "ISENTO"
  inscricaoEstadualST  String?             // IE Substituto Tributário
  inscricaoMunicipal   String?
  nomeFantasia         String?
  cnaePrincipal        String?             // FK para CnaeCode.codigo
  crt                  Crt?                // CRT 1/2/3/4 — sem default (obrigatório explícito)
  regimeEspecial       RegimeEspecial      @default(SEM_REGIME)
  estabelecimento      Estabelecimento?    // MATRIZ/FILIAL — null indica pendência
  indicadorAtividade   IndicadorAtividade? // null indica pendência
  produtorRural        Boolean             @default(false)
  usarCstCsosn         UsarCstCsosn        @default(NAO)
  isActive             Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  company              Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  cnae                 CnaeCode? @relation(fields: [cnaePrincipal], references: [codigo])

  @@index([cnaePrincipal])
}

// ─── Endereço fiscal estruturado (1:1 com Company) ─────────────────────────

model CompanyAddress {
  id                 String   @id @default(uuid())
  companyId          String   @unique
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  cep                String?  // 8 dígitos, sem máscara
  codIbgeMunicipio   String?  // 7 dígitos — vai como cMun no XML NF-e
  municipio          String?  // nome do município — vai como xMun
  uf                 String?  // 2 chars — UF
  codPais            String?  @default("1058")    // 1058 = Brasil
  pais               String?  @default("BRASIL")
  referencia         String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─── Configuração NF-e modelo 55 (1:1 com Company) ─────────────────────────

model CompanyNfeConfig {
  id                          String            @id @default(uuid())
  companyId                   String            @unique

  // Numeração e série
  serie                       String            @default("1")  // 1-3 dígitos
  ultimaNfe                   Int               @default(0)    // último nNF emitido — próximo = +1

  // Tributação no Simples
  aliquotaCreditoSimples      Decimal?          @db.Decimal(5, 2)  // % crédito Simples Nacional

  // DANFE e ambiente
  danfeSimplificado           Boolean           @default(false)
  ambiente                    AmbienteSefaz     @default(HOMOLOGACAO)
  observacoes                 String?           // texto padrão para infCpl

  // Contingência
  tipoContingencia            TipoContingencia  @default(NORMAL)
  contingenciaJustificativa   String?           // obrigatório se tipoContingencia != NORMAL (mín. 15 chars — valida no DTO)
  contingenciaInicio          DateTime?

  // Parametrização básica
  calcularIcmsDesonerado      Boolean           @default(false)
  incluirFreteBaseIcms        Boolean           @default(true)
  destacarValorIcmsSt         Boolean           @default(false)

  isActive                    Boolean           @default(true)
  createdAt                   DateTime          @default(now())
  updatedAt                   DateTime          @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─── Catálogo NCM (Nomenclatura Comum do Mercosul) ──────────────────────────

model NcmCode {
  codigo     String   @id              // 8 dígitos sem máscara (ex: "01012100")
  descricao  String

  // hierarquia (derivada do código)
  capitulo   String                    // 2 dígitos
  posicao    String                    // 4 dígitos
  subposicao String                    // 6 dígitos

  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  products   Product[]

  @@index([capitulo])
  @@index([descricao])
}

// ─── Catálogo CFOP (Código Fiscal de Operações e Prestações) ────────────────

model CfopCode {
  codigo    String   @id              // 4 dígitos (ex: "5102")
  descricao String
  natureza  String                    // "ENTRADA" | "SAIDA" (derivado do primeiro dígito)
  grupo     String                    // primeiro dígito como string ("1","2","3","5","6","7")
  aplicacao String?                   // descrição complementar opcional

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]

  @@index([grupo])
  @@index([natureza])
}

// ─── Catálogo CST ICMS (Código Situação Tributária) ─────────────────────────

model CstIcmsCode {
  codigo     String   @id              // 2 dígitos (ex: "00", "10", "20")
  descricao  String
  observacao String?

  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  products   Product[]
}

// ─── Catálogo CSOSN (Código Situação da Operação no Simples Nacional) ───────

model CsosnCode {
  codigo     String   @id              // 3 dígitos (ex: "101", "102", "201"...)
  descricao  String
  observacao String?

  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  products   Product[]
}

// ─── Catálogo IBGE — Municípios brasileiros ─────────────────────────────────

model IbgeMunicipio {
  codigo    String   @id              // 7 dígitos (ex: "3550308" = São Paulo)
  nome      String                    // "São Paulo"
  uf        String   @db.Char(2)      // "SP"

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([uf])
  @@index([uf, nome])
  @@index([nome])
}

// ─── Clientes/Destinatários (por empresa) ───────────────────────────────────

model Customer {
  id                  String       @id @default(uuid())
  companyId           String

  // Dados gerais (PF/PJ)
  tipoPessoa          TipoPessoa
  cpfCnpj             String                                // 11 (CPF) ou 14 (CNPJ) dígitos
  name                String                                // razão social ou nome PF
  nomeFantasia        String?                               // só PJ
  inscricaoEstadual   String?                               // só PJ + indicadorIe = CONTRIBUINTE_ICMS
  indicadorIe         IndicadorIeDestinatario @default(NAO_CONTRIBUINTE)
  inscricaoSuframa    String?                               // zonas francas
  email               String?
  phone               String?

  // Endereço (mesmo padrão de CompanyAddress)
  logradouro          String?
  numero              String?
  complemento         String?
  bairro              String?
  cep                 String?
  codIbgeMunicipio    String?
  municipio           String?
  uf                  String?
  codPais             String?      @default("1058")
  pais                String?      @default("BRASIL")

  notes               String?
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  company             Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  nfes                Nfe[]

  @@unique([companyId, cpfCnpj])
  @@index([companyId])
  @@index([cpfCnpj])
  @@index([name])
}

// ─── Produtos/Serviços (por empresa) ────────────────────────────────────────

model Product {
  id                  String       @id @default(uuid())
  companyId           String

  // Identificação
  codigoInterno       String                                // cProd
  codigoBarras        String?                               // cEAN/GTIN
  descricao           String                                // xProd

  // Classificação fiscal
  ncmCodigo           String?                               // FK → NcmCode.codigo (8 díg)
  cestCodigo          String?                               // string livre — catálogo CEST em fase futura
  cfopPadrao          String?                               // FK → CfopCode.codigo (4 díg)
  unidade             String                                // uCom (ex: "UN", "KG", "L", "PC")
  origem              MercadoriaOrigem @default(NACIONAL)

  // Tributação padrão (depende do CRT da empresa)
  cstIcmsPadrao       String?                               // FK → CstIcmsCode (quando CRT = REGIME_NORMAL)
  csosnPadrao         String?                               // FK → CsosnCode (quando CRT = SIMPLES_NACIONAL/MEI)
  aliquotaIcms        Decimal?     @db.Decimal(5, 2)        // %
  aliquotaPis         Decimal?     @db.Decimal(5, 2)
  aliquotaCofins      Decimal?     @db.Decimal(5, 2)
  aliquotaIpi         Decimal?     @db.Decimal(5, 2)

  // Comercial
  precoVenda          Decimal      @db.Decimal(10, 2)
  precoCusto          Decimal?     @db.Decimal(10, 2)

  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  company             Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ncm                 NcmCode?     @relation(fields: [ncmCodigo], references: [codigo])
  cfop                CfopCode?    @relation(fields: [cfopPadrao], references: [codigo])
  cstIcms             CstIcmsCode? @relation(fields: [cstIcmsPadrao], references: [codigo])
  csosn               CsosnCode?   @relation(fields: [csosnPadrao], references: [codigo])
  nfeItens            NfeItem[]

  @@unique([companyId, codigoInterno])
  @@index([companyId])
  @@index([descricao])
  @@index([ncmCodigo])
  @@index([cfopPadrao])
}

// ─── NF-e emitida (cabeçalho) ──────────────────────────────────────────────

model Nfe {
  id                   String           @id @default(uuid())
  companyId            String
  customerId           String

  // Identificação
  serie                String                                      // copiado do CompanyNfeConfig no momento da criação
  numero               Int?                                        // null em rascunho — atribuído ao transmitir
  chave                String?          @unique                    // 44 dígitos — gerada ao transmitir

  // Status / ciclo de vida
  status               NfeStatus        @default(RASCUNHO)

  // Configuração fiscal
  finalidade           NfeFinalidade    @default(NORMAL)
  naturezaOperacao     String                                      // ex: "Venda de mercadoria"
  tipoOperacao         NfeTipoOperacao
  modFrete             NfeModFrete      @default(SEM_TRANSPORTE)
  indicadorPresenca    String?                                     // indPres: 0..5,9

  // Totais (recalculados a partir dos itens)
  totalProdutos        Decimal          @default(0)  @db.Decimal(15, 2)
  totalFrete           Decimal          @default(0)  @db.Decimal(15, 2)
  totalDesconto        Decimal          @default(0)  @db.Decimal(15, 2)
  totalSeguro          Decimal          @default(0)  @db.Decimal(15, 2)
  totalOutros          Decimal          @default(0)  @db.Decimal(15, 2)
  totalIcms            Decimal          @default(0)  @db.Decimal(15, 2)
  totalIcmsSt          Decimal          @default(0)  @db.Decimal(15, 2)
  totalIpi             Decimal          @default(0)  @db.Decimal(15, 2)
  totalPis             Decimal          @default(0)  @db.Decimal(15, 2)
  totalCofins          Decimal          @default(0)  @db.Decimal(15, 2)
  totalNota            Decimal          @default(0)  @db.Decimal(15, 2)

  // Observações
  observacoesFiscais   String?                                     // infAdFisco
  observacoesContrib   String?                                     // infCpl

  // Resposta SEFAZ (após transmissão)
  protocoloAutorizacao String?
  dataAutorizacao      DateTime?
  cStat                String?
  xMotivo              String?
  xmlAssinado          String?          @db.Text                   // gzip base64 — XML assinado antes do envio
  xmlAutorizado        String?          @db.Text                   // gzip base64 — XML com protNFe (final)

  // Cancelamento (preenchido por evento)
  justifCancelamento   String?
  dataCancelamento     DateTime?

  isActive             Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  company              Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer             Customer         @relation(fields: [customerId], references: [id])
  itens                NfeItem[]
  pagamentos           NfePagamento[]
  eventos              NfeEvento[]

  @@unique([companyId, serie, numero])  // numero só preenchido após transmitir; nulls múltiplos permitidos
  @@index([companyId])
  @@index([customerId])
  @@index([status])
  @@index([dataAutorizacao])
}

// ─── Itens da NF-e (snapshot por nota) ─────────────────────────────────────

model NfeItem {
  id                  String           @id @default(uuid())
  nfeId               String
  productId           String
  ordem               Int                                          // nItem (1-based)

  // Identificação (defaults vindos do Product, podem ser sobrescritos)
  cfop                String                                       // pode diferir do CFOP padrão do Product
  unidade             String

  // Quantidade e valor
  quantidade          Decimal          @db.Decimal(15, 4)
  valorUnitario       Decimal          @db.Decimal(15, 4)
  desconto            Decimal          @default(0)  @db.Decimal(15, 2)
  valorTotal          Decimal          @db.Decimal(15, 2)          // qtd * vUnit - desconto

  // ICMS (CST se CRT=Regime Normal, CSOSN se CRT=Simples)
  origem              MercadoriaOrigem
  cstIcms             String?                                      // 2 dígitos (CST) ou 3 dígitos (CSOSN)
  baseCalcIcms        Decimal?         @db.Decimal(15, 2)
  aliquotaIcms        Decimal?         @db.Decimal(5, 2)
  valorIcms           Decimal?         @db.Decimal(15, 2)
  baseCalcIcmsSt      Decimal?         @db.Decimal(15, 2)
  aliquotaIcmsSt      Decimal?         @db.Decimal(5, 2)
  valorIcmsSt         Decimal?         @db.Decimal(15, 2)

  // PIS
  cstPis              String?
  baseCalcPis         Decimal?         @db.Decimal(15, 2)
  aliquotaPis         Decimal?         @db.Decimal(5, 2)
  valorPis            Decimal?         @db.Decimal(15, 2)

  // COFINS
  cstCofins           String?
  baseCalcCofins      Decimal?         @db.Decimal(15, 2)
  aliquotaCofins      Decimal?         @db.Decimal(5, 2)
  valorCofins         Decimal?         @db.Decimal(15, 2)

  // IPI
  cstIpi              String?
  baseCalcIpi         Decimal?         @db.Decimal(15, 2)
  aliquotaIpi         Decimal?         @db.Decimal(5, 2)
  valorIpi            Decimal?         @db.Decimal(15, 2)

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  nfe                 Nfe              @relation(fields: [nfeId], references: [id], onDelete: Cascade)
  product             Product          @relation(fields: [productId], references: [id])

  @@unique([nfeId, ordem])
  @@index([nfeId])
  @@index([productId])
}

// ─── Pagamentos da NF-e ────────────────────────────────────────────────────

model NfePagamento {
  id                  String           @id @default(uuid())
  nfeId               String
  formaPagamento      String                                       // codSefaz: "01" dinheiro, "03" cartão crédito, "17" PIX, "90" sem pagto, "99" outros
  valor               Decimal          @db.Decimal(15, 2)

  createdAt           DateTime         @default(now())

  nfe                 Nfe              @relation(fields: [nfeId], references: [id], onDelete: Cascade)

  @@index([nfeId])
}

// ─── Eventos da NF-e (cancelamento, CC-e, etc.) ────────────────────────────

model NfeEvento {
  id                  String           @id @default(uuid())
  nfeId               String
  tpEvento            String                                       // "110110" CC-e, "110111" cancelamento
  sequencia           Int              @default(1)                 // nSeqEvento (1..N)
  justificativa       String?
  status              String           @default("PENDING")         // PENDING | AUTORIZADO | REJEITADO
  protocolo           String?
  cStat               String?
  xMotivo             String?
  xmlEnvio            String?          @db.Text
  xmlResposta         String?          @db.Text

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  nfe                 Nfe              @relation(fields: [nfeId], references: [id], onDelete: Cascade)

  @@unique([nfeId, tpEvento, sequencia])
  @@index([nfeId])
}

// ─── Inutilização de numeração NF-e ────────────────────────────────────────

model NfeInutilizacao {
  id              String   @id @default(uuid())
  companyId       String

  // Faixa inutilizada
  serie           String
  numeroInicial   Int
  numeroFinal     Int
  ano             Int                                    // AAAA (ano da inutilização)
  justificativa   String                                 // 15-255 chars

  // Resposta SEFAZ
  status          String   @default("PENDING")           // PENDING | HOMOLOGADA | REJEITADA
  protocolo       String?                                // nProt do retorno
  cStat           String?
  xMotivo         String?
  dhRecbto        DateTime?
  xmlEnvio        String?  @db.Text
  xmlResposta     String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, serie, numeroInicial, numeroFinal, ano])
  @@index([companyId])
}


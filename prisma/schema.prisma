generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum DocumentType {
  DAS
  CONTRACT
  INVOICE
  TAX_REPORT
  OTHER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum RecurrenceInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum BillingCycle {
  MONTH
  YEAR
}

// ─── Auth interna (contador / equipe) ────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  password             String
  isActive             Boolean   @default(true)
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  ownedTeams    Team[]       @relation("TeamOwner")
  teamMembers   TeamMember[]
  createdTasks  Task[]       @relation("TaskCreator")
  assignedTasks Task[]       @relation("TaskAssignee")
}

// ─── Planos ───────────────────────────────────────────────────────────────────

model Plan {
  id                 String   @id
  name               String
  description        String
  priceMonthly       Int?
  priceYearly        Int?
  features           String[]
  idProductMonthly   String?
  idProductYearly    String?
  url                String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  teams Team[]
}

// ─── Escritório / Workspace ───────────────────────────────────────────────────

model Team {
  id                 String    @id @default(uuid())
  name               String
  ownerId            String
  isActive           Boolean   @default(true)
  planId             String?
  billingCycle       BillingCycle @default(MONTH)
  subscriptionStatus String    @default("INACTIVE")
  subscriptionId     String?
  customerId         String?
  subscriptionExpiry DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  owner     User         @relation("TeamOwner", fields: [ownerId], references: [id])
  plan      Plan?        @relation(fields: [planId], references: [id])
  members   TeamMember[]
  companies Company[]
  boards     Board[]
  tasks      Task[]
  driveItems DriveItem[]
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
}

// ─── Empresa cliente ─────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(uuid())
  teamId    String
  name      String
  cnpj      String?  @unique
  email     String?
  phone     String?
  address   String?
  isActive      Boolean   @default(true)
  sefazUltNsu   String?
  sefazLastSync DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  team            Team                @relation(fields: [teamId], references: [id])
  companyUsers    CompanyUser[]
  driveShares     DriveItemShare[]
  tasks           Task[]
  serviceRequests ServiceRequest[]
  payments        Payment[]
  certificate     CompanyCertificate?
  sefazNFes       SefazNFe[]
  sefazEventos    SefazEvento[]
}

// ─── Portal cliente (login da empresa) ───────────────────────────────────────

model CompanyUser {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String   @unique
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id])
  serviceRequests ServiceRequest[]
}

// ─── Drive Unificado ──────────────────────────────────────────────────────────

model DriveItem {
  id          String  @id @default(uuid())
  teamId      String
  name        String
  path        String  // "/DAS/2024/Janeiro" ou "/DAS/2024/Janeiro/arquivo.pdf"
  isDirectory Boolean @default(false)

  // Metadados do arquivo (quando isDirectory = false)
  fileUrl  String?
  mimeType String?
  size     Int?

  // Campos extras
  description     String?
  competenceMonth Int? // 1-12 (para DAS, boletos, etc)
  competenceYear  Int? // 2024, 2025...

  // Controle
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team   Team             @relation(fields: [teamId], references: [id])
  shares DriveItemShare[]

  @@unique([teamId, path])
  @@index([teamId, path])
}

// Compartilhamento com empresas específicas
model DriveItemShare {
  id          String   @id @default(uuid())
  driveItemId String
  companyId   String
  canUpload   Boolean  @default(false) // Cliente pode fazer upload nessa pasta
  createdAt   DateTime @default(now())

  driveItem DriveItem @relation(fields: [driveItemId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id])

  @@unique([driveItemId, companyId])
}

// ─── Certificado digital da empresa ──────────────────────────────────────────

model CompanyCertificate {
  id        String    @id @default(uuid())
  companyId String    @unique
  certUrl   String
  password  String
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

// ─── Documentos fiscais SEFAZ ────────────────────────────────────────────────

model SefazNFe {
  id             String    @id @default(uuid())
  companyId      String
  chave          String
  nsu            String?
  tipo           String?   // EMITIDA | RECEBIDA
  status         String    @default("AUTORIZADA") // AUTORIZADA | CANCELADA
  emitenteCnpj   String?
  emitenteNome   String?
  destinCnpj     String?
  destinNome     String?
  valor          Decimal?  @db.Decimal(15, 2)
  serie          String?
  numero         String?
  dataEmissao    DateTime?
  xmlGzip        String?   @db.Text
  temXmlCompleto Boolean   @default(false)
  modelo         String?   // 55 = NF-e | 65 = NFC-e
  manifestacao   String?   // CIENCIA | CONFIRMADA | DESCONHECIMENTO | NAO_REALIZADA
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company  Company       @relation(fields: [companyId], references: [id])
  eventos  SefazEvento[]

  @@unique([companyId, chave])
}

model SefazEvento {
  id         String    @id @default(uuid())
  companyId  String
  nfeId      String?
  chaveNFe   String
  nsu        String
  tpEvento   String?
  xEvento    String?
  dataEvento DateTime?
  protocolo  String?
  schema     String
  xmlGzip    String    @db.Text
  createdAt  DateTime  @default(now())

  company Company    @relation(fields: [companyId], references: [id])
  nfe     SefazNFe?  @relation(fields: [nfeId], references: [id])

  @@unique([companyId, nsu])
}

// ─── Quadros / Setores ───────────────────────────────────────────────────────

model Board {
  id        String   @id @default(uuid())
  teamId    String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team  Team   @relation(fields: [teamId], references: [id])
  tasks Task[]
}

// ─── Tarefas ─────────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(uuid())
  teamId      String
  boardId     String
  companyId   String?
  parentId    String?
  title       String
  description String?
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  assigneeId  String?
  creatorId   String
  order       Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  team           Team                @relation(fields: [teamId], references: [id])
  board          Board               @relation(fields: [boardId], references: [id])
  company        Company?            @relation(fields: [companyId], references: [id])
  assignee       User?               @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator        User                @relation("TaskCreator", fields: [creatorId], references: [id])
  parent         Task?               @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks       Task[]              @relation("TaskSubtasks")
  checklistItems TaskChecklistItem[]
}

// ─── Checklist de Tarefas ────────────────────────────────────────────────────

model TaskChecklistItem {
  id        String   @id @default(uuid())
  taskId    String
  text      String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ─── Pedidos / Solicitações do cliente ───────────────────────────────────────

model ServiceRequest {
  id            String               @id @default(uuid())
  companyId     String
  companyUserId String
  title         String
  description   String?
  status        ServiceRequestStatus @default(OPEN)
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  company     Company     @relation(fields: [companyId], references: [id])
  companyUser CompanyUser @relation(fields: [companyUserId], references: [id])
}

// ─── Cobranças ────────────────────────────────────────────────────────────────

model Payment {
  id                  String              @id @default(uuid())
  companyId           String
  description         String
  amount              Decimal             @db.Decimal(10, 2)
  dueDate             DateTime
  status              PaymentStatus       @default(PENDING)
  paidAt              DateTime?
  referenceMonth      String?
  isRecurring         Boolean             @default(false)
  recurrenceInterval  RecurrenceInterval?
  recurrenceEndDate   DateTime?
  recurrenceGroupId   String?
  isActive            Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

